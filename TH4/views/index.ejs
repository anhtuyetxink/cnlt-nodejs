<!DOCTYPE html>
<html>
<head>
  <link rel="stylesheet" href="/style.css">
</head>
<body>
<div class="container">

<h1>Blog</h1>

<a href="/blogposts/new"><button>+ Tạo bài</button></a>

<% posts.forEach(post => { %>
  <div class="card">
    <h3><%= post.title %></h3>
    <p><%= post.body.substring(0, 100) %></p>

    <a href="/blogposts/<%= post._id %>">Xem</a>
    <a href="/edit/<%= post._id %>">Sửa</a>
    <a href="/delete/<%= post._id %>" onclick="return confirm('Xoá?')">Xoá</a>
  </div>
<% }) %>

</div>
</body>
</html>